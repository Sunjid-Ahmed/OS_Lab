#include <stdio.h>
struct process {
    char id[5];
    int at, bt, pr;
    int ct, tat, wt;
};

void sort(struct process p[], int n) {
    int i, j;
    struct process temp;

    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {

            if(p[i].pr > p[j].pr ||
               (p[i].pr == p[j].pr && p[i].at > p[j].at) ||
               (p[i].pr == p[j].pr && p[i].at == p[j].at && p[i].bt > p[j].bt)) {

                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }
}

int main() {
    int n = 4, i;
    struct process p[4] = {
        {"P1", 3, 2, 1},
        {"P2", 5, 1, 3},
        {"P3", 6, 7, 4},
        {"P4", 3, 3, 1}
    };
    sort(p, n);

    int time = 0;

    for(i = 0; i < n; i++) {
        if(time < p[i].at)
            time = p[i].at;

        p[i].ct = time + p[i].bt;
        p[i].tat = p[i].ct - p[i].at;
        p[i].wt = p[i].tat - p[i].bt;

        time = p[i].ct;
    }

    printf("\nProcess\tAT\tBT\tPR\tCT\tTAT\tWT\n");

    for(i = 0; i < n; i++) {
        printf("%s\t%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].id, p[i].at, p[i].bt, p[i].pr,
               p[i].ct, p[i].tat, p[i].wt);
    }

    return 0;
}
